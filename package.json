  "private": true,
  "description": "Monorepo root for synapse-chat: AI CLI chat framework (WS + React + process manager).",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizunowanko/synapse-chat.git"
  },
